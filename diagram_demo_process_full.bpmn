<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1lhyiyx" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="process-order" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Order Placed (Tiến trình đặt hàng)">
      <bpmn:extensionElements />
      <bpmn:outgoing>Flow_1np3eje</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0wd6ala" name="Validate Order&#10;(Ktra đơn hàng)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="validate-order" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1np3eje</bpmn:incoming>
      <bpmn:incoming>Flow_1kfe9hx</bpmn:incoming>
      <bpmn:outgoing>Flow_0b3y2vt</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1np3eje" sourceRef="StartEvent_1" targetRef="Activity_0wd6ala" />
    <bpmn:exclusiveGateway id="Gateway_1oysd8x" name="Is Valid?">
      <bpmn:incoming>Flow_0b3y2vt</bpmn:incoming>
      <bpmn:outgoing>Flow_1m551yu</bpmn:outgoing>
      <bpmn:outgoing>Flow_1a1w4ik</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0b3y2vt" sourceRef="Activity_0wd6ala" targetRef="Gateway_1oysd8x" />
    <bpmn:serviceTask id="Activity_1febvf6" name="Process Payment (Tiến trình bắt đầu thanh toán)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="process-payment" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1m551yu</bpmn:incoming>
      <bpmn:outgoing>Flow_021bx7b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1m551yu" name="Yes" sourceRef="Gateway_1oysd8x" targetRef="Activity_1febvf6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isValid = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_1cnrm6h" name="Check Inventory (Ktra tồn kho)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="check-inventory" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_021bx7b</bpmn:incoming>
      <bpmn:outgoing>Flow_1xllslr</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_021bx7b" sourceRef="Activity_1febvf6" targetRef="Activity_1cnrm6h" />
    <bpmn:exclusiveGateway id="Gateway_13huk9d" name="In Stock?">
      <bpmn:incoming>Flow_1xllslr</bpmn:incoming>
      <bpmn:outgoing>Flow_1yy4n2i</bpmn:outgoing>
      <bpmn:outgoing>Flow_03uco1l</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1xllslr" sourceRef="Activity_1cnrm6h" targetRef="Gateway_13huk9d" />
    <bpmn:userTask id="Activity_05gg3ju" name="Fulfill Order (Hoàn thành đơn đặt hàng)">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="delivery_to_shipper" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0ftp8h3</bpmn:incoming>
      <bpmn:outgoing>Flow_10it7np</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_01wa9w9" name="Send Shipping Notification (Thông báo gửi hàng)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-shipping-notification" retries="5" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_10it7np</bpmn:incoming>
      <bpmn:outgoing>Flow_1ls4vbz</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_10it7np" sourceRef="Activity_05gg3ju" targetRef="Activity_01wa9w9" />
    <bpmn:endEvent id="Event_0dp7a8k" name="Orde Rejected">
      <bpmn:incoming>Flow_1a1w4ik</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateEventDefinition_1of2zt9" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1a1w4ik" name="No" sourceRef="Gateway_1oysd8x" targetRef="Event_0dp7a8k">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isValid = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:boundaryEvent id="Event_14khpsz" name="Fail" attachedToRef="Activity_1febvf6">
      <bpmn:outgoing>Flow_1p0gn85</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1fyipx4" errorRef="Error_1bts3b3" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_1p0gn85" sourceRef="Event_14khpsz" targetRef="Activity_0elbyb5" />
    <bpmn:endEvent id="Event_0zrmitz" name="Order Cancelled">
      <bpmn:incoming>Flow_09ug27z</bpmn:incoming>
      <bpmn:incoming>Flow_19kikif</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1yy4n2i" name="No" sourceRef="Gateway_13huk9d" targetRef="Activity_18wtvo0">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=inventoryAvailable = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_09ug27z" sourceRef="Activity_18wtvo0" targetRef="Event_0zrmitz" />
    <bpmn:serviceTask id="Activity_0elbyb5" name="Handle Payment Failure &#10;(Xử lý thanh toán thất bại)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="handle-payment-failure" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1p0gn85</bpmn:incoming>
      <bpmn:outgoing>Flow_13qswyp</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_18wtvo0" name="Notify Out of Stock (Thông báo hết hàng)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notify-out-of-stock" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1yy4n2i</bpmn:incoming>
      <bpmn:outgoing>Flow_09ug27z</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_1xgkpdz" name="Shop đang kiểm tra và chuẩn bị đơn hàng">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03uco1l</bpmn:incoming>
      <bpmn:outgoing>Flow_0ftp8h3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_03uco1l" name="Yes" sourceRef="Gateway_13huk9d" targetRef="Activity_1xgkpdz">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=inventoryAvailable = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0ftp8h3" sourceRef="Activity_1xgkpdz" targetRef="Activity_05gg3ju" />
    <bpmn:boundaryEvent id="Event_1oth38d" name="Khách huỷ đơn" attachedToRef="Activity_1xgkpdz">
      <bpmn:outgoing>Flow_0eqpm4q</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_132yaom" messageRef="Message_07l82me" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_09cyz1k" name="Retry">
      <bpmn:incoming>Flow_13qswyp</bpmn:incoming>
      <bpmn:outgoing>Flow_1kfe9hx</bpmn:outgoing>
      <bpmn:outgoing>Flow_19kikif</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_13qswyp" sourceRef="Activity_0elbyb5" targetRef="Gateway_09cyz1k" />
    <bpmn:sequenceFlow id="Flow_1kfe9hx" name="&#60;= 3" sourceRef="Gateway_09cyz1k" targetRef="Activity_0wd6ala">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=retryCount &lt;= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_19kikif" name="&#62; 3 (huỷ tiến trình)" sourceRef="Gateway_09cyz1k" targetRef="Event_0zrmitz">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=retryCount &gt; 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_0212gkv" name="Shop xác nhận huỷ">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0eqpm4q</bpmn:incoming>
      <bpmn:outgoing>Flow_11yx2ej</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0eqpm4q" sourceRef="Event_1oth38d" targetRef="Activity_0212gkv" />
    <bpmn:endEvent id="Event_1sdiw9c" name="Cancelled Order">
      <bpmn:incoming>Flow_11yx2ej</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_11yx2ej" sourceRef="Activity_0212gkv" targetRef="Event_1sdiw9c" />
    <bpmn:endEvent id="Event_0nn12l4" name="Inform Customer&#10;Order success">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order-success-send-mail" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="={&#10;  message: &#34;Hoàn tất đơn hàng, đã được gửi đi&#34;&#10;}" target="InputVariable_0vm4i0o" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ls4vbz</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1hw8xuj" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1ls4vbz" sourceRef="Activity_01wa9w9" targetRef="Event_0nn12l4" />
    <bpmn:textAnnotation id="TextAnnotation_14sevia">
